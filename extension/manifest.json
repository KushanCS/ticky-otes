{
  "manifest_version": 3,
  "name": "AI Branch Cards",
  "version": "1.0.0",
  "description": "Create context-aware branch cards on ChatGPT.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ],
      "css": ["styles/glass.css"],
      "js": [
        "utils/constants.js",
        "utils/helpers.js",
        "utils/storage.js",
        "utils/api.js",
        "features/contextExtractor.js",
        "features/sidebar.js",
        "features/cards.js",
        "features/selection.js",
        "content.js"
      ]
    }
  ]
}
